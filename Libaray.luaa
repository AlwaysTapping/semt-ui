                Name = Params.Name or "Slider",
                Flag = Params.Flag or Params.Name or "Slider",
                Default = Params.Default or 0,
                Min = Params.Min or 0,
                Max = Params.Max or 100,
                Callback = Params.Callback or function() end,
                Decimals = Params.Decimals or 1,
