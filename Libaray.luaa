                    BackgroundTransparency = 1,
                    BorderSizePixel = 0,
                    Size = UDim2.new(0, 45, 0, 14)
                }):AddToTheme({TextColor3 = 'Inactive Text'})

                Slider.Items = Items 
            end

            Items["RealSlider"]:OnHover(function()
                Items["RealSlider"]:Tween({BackgroundColor3 = Library.Theme["Hovered Element"]})
            end, function()
                Items["RealSlider"]:Tween({BackgroundColor3 = Library.Theme["Element 2"]})
            end)

            function Slider:Set(Value)
                Slider.Value = Library:Round(math.clamp(Value, Slider.Min, Slider.Max), Slider.Decimals)

                local Percent = (Slider.Value - Slider.Min) / (Slider.Max - Slider.Min)
                Items["Accent"]:Tween({Size = UDim2.new(Percent, 0, 1, 0)})
                Items["Value"].Instance.Text = Slider.Value .. Slider.Suffix

                Library.Flags[Slider.Flag] = Slider.Value
                Library:SafeCall(Slider.Callback, Slider.Value)
            end

            function Slider:SetVisibility(Bool)
                Items["Slider"].Instance.Visible = Bool
            end

            function Slider:SetText(Text)
                Items["Text"].Instance.Text = tostring(Text)
            end

            Items["RealSlider"]:Connect("InputBegan", function(Input)
                if Input.UserInputType == Enum.UserInputType.MouseButton1 then
                    Slider.Sliding = true
                    local X = math.clamp((Input.Position.X - Items["RealSlider"].Instance.AbsolutePosition.X) / Items["RealSlider"].Instance.AbsoluteSize.X, 0, 1)
                    local Value = Slider.Min + (Slider.Max - Slider.Min) * X
                    Slider:Set(Value)
                end
            end)

            Items["RealSlider"]:Connect("InputEnded", function()
                Slider.Sliding = false
            end)

            Library:Connect(UserInputService.InputChanged, function(Input)
                if Input.UserInputType == Enum.UserInputType.MouseMovement and Slider.Sliding then
                    local X = math.clamp((Input.Position.X - Items["RealSlider"].Instance.AbsolutePosition.X) / Items["RealSlider"].Instance.AbsoluteSize.X, 0, 1)
                    local Value = Slider.Min + (Slider.Max - Slider.Min) * X
                    Slider:Set(Value)
                end
            end)

            Slider:Set(Slider.Default)

            Library.SetFlags[Slider.Flag] = function(Value)
                Slider:Set(Value)
            end

            return setmetatable(Slider, Library)
        end

        Library.Dropdown = function(Self, Params)
            Params = Params or { }

            local Dropdown = {
                Name = Params.Name or "Dropdown",
                OptionItems = Params.Items or {},
                Flag = Params.Flag or Params.Name or "Dropdown",
                Default = Params.Default or "",
                Callback = Params.Callback or function() end,
                Multi = Params.Multi or false,
                Section = Self,
                Value = nil,
                Options = {},
                IsOpen = false,
                Items = {}
            }

            local Parent = Params.Parent or Dropdown.Section.Items["Content"]

            local Items = { } do 
                Items["Dropdown"] = Library:Create("Frame", {
                    Parent = Parent.Instance,
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 0, 40),
                    BorderSizePixel = 0
                })
                
                Items["Text"] = Library:Create("TextLabel", {
                    FontFace = Library.Font,
                    TextSize = Library.FontSize,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    Parent = Items["Dropdown"].Instance,
                    TextColor3 = Library.Theme["Text"],
                    Text = Dropdown.Name,
                    BackgroundTransparency = 1,
                    BorderSizePixel = 0,
                    AutomaticSize = Enum.AutomaticSize.XY
                }):AddToTheme({TextColor3 = 'Text'})
                
                Items["RealDropdown"] = Library:Create("TextButton", {
                    FontFace = Library.Font,
                    TextSize = Library.FontSize,
                    Parent = Items["Dropdown"].Instance,
                    TextColor3 = Color3.fromRGB(0, 0, 0),
                    Text = "",
                    AutoButtonColor = false,
                    AnchorPoint = Vector2.new(0, 1),
                    Position = UDim2.new(0, 0, 1, 0),
                    Size = UDim2.new(1, 0, 0, 20),
                    BorderSizePixel = 0,
                    BackgroundColor3 = Library.Theme["Element"]
                }):AddToTheme({BackgroundColor3 = 'Element'})
                
                Items["Value"] = Library:Create("TextLabel", {
                    FontFace = Library.Font,
                    TextSize = Library.FontSize,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    Parent = Items["RealDropdown"].Instance,
                    TextColor3 = Library.Theme["Text"],
                    Text = "none",
                    Position = UDim2.new(0, 8, 0.5, -1),
                    AnchorPoint = Vector2.new(0, 0.5),
                    BorderSizePixel = 0,
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, -30, 0, 14)
                }):AddToTheme({TextColor3 = 'Text'})
                
                Items["Icon"] = Library:Create("ImageLabel", {
                    Parent = Items["RealDropdown"].Instance,
                    ImageColor3 = Library.Theme["Accent"],
                    AnchorPoint = Vector2.new(1, 0.5),
                    Image = "rbxassetid://6031098373",
                    BackgroundTransparency = 1,
                    Position = UDim2.new(1, -8, 0.5, 0),
                    Size = UDim2.new(0, 12, 0, 12)
                }):AddToTheme({ImageColor3 = 'Accent'})
                
                Items["OptionHolder"] = Library:Create("Frame", {
                    Parent = Library.Holder.Instance,
                    Visible = false,
                    Size = UDim2.new(0, 200, 0, 100),
                    BackgroundColor3 = Library.Theme["Background"],
                    BorderSizePixel = 0,
                    AutomaticSize = Enum.AutomaticSize.Y,
                    ZIndex = 10
                }):AddToTheme({BackgroundColor3 = 'Background'})
                
                Library:Create("UIStroke", {
                    Parent = Items["OptionHolder"].Instance,
                    Color = Library.Theme["Border"]
                }):AddToTheme({Color = 'Border'})
                
                Items["OptionList"] = Library:Create("UIListLayout", {
                    Parent = Items["OptionHolder"].Instance,
                    Padding = UDim.new(0, 4)
                })

                Dropdown.Items = Items
            end

            Items["RealDropdown"]:OnHover(function()
                Items["RealDropdown"]:Tween({BackgroundColor3 = Library.Theme["Hovered Element"]})
            end, function()
                Items["RealDropdown"]:Tween({BackgroundColor3 = Library.Theme["Element"]})
            end)

            function Dropdown:Set(Value)
                if Dropdown.Multi then
                    if type(Value) ~= "table" then
                        return
                    end
                    Dropdown.Value = Value
                    local Text = #Value > 0 and table.concat(Value, ", ") or "none"
                    Items["Value"].Instance.Text = Text
                    
                    for _, Option in pairs(Dropdown.Options) do
                        local selected = false
                        for _, v in pairs(Value) do
                            if v == Option.Name then
                                selected = true
                                break
                            end
                        end
                        Option:SetSelected(selected)
                    end
                else
                    if not Dropdown.Options[Value] then
                        return
                    end
                    Dropdown.Value = Value
                    Items["Value"].Instance.Text = Value
                    
                    for _, Option in pairs(Dropdown.Options) do
                        Option:SetSelected(Option.Name == Value)
                    end
                end
                
                Library.Flags[Dropdown.Flag] = Dropdown.Value
                Library:SafeCall(Dropdown.Callback, Dropdown.Value)
            end

            function Dropdown:Add(Value)
                local OptionButton = Library:Create("TextButton", {
                    FontFace = Library.Font,
                    TextSize = Library.FontSize,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    Parent = Items["OptionHolder"].Instance,
                    TextColor3 = Library.Theme["Text"],
                    Text = Value,
                    AutoButtonColor = false,
                    Size = UDim2.new(1, 0, 0, 20),
                    BackgroundColor3 = Library.Theme["Element"],
                    BorderSizePixel = 0,
                    ZIndex = 11
                }):AddToTheme({BackgroundColor3 = 'Element', TextColor3 = 'Text'})

                local OptionData = {
                    Button = OptionButton,
                    Name = Value,
                    IsSelected = false
                }

                OptionButton:OnHover(function()
                    OptionButton:Tween({BackgroundColor3 = Library.Theme["Hovered Element"]})
                end, function()
                    OptionButton:Tween({BackgroundColor3 = Library.Theme["Element"]})
                end)
                
                function OptionData:SetSelected(Selected)
                    self.IsSelected = Selected
                    if Selected then
                        OptionButton:ChangeItemTheme({BackgroundColor3 = "Accent", TextColor3 = "Text"})
                        OptionButton:Tween({BackgroundColor3 = Library.Theme.Accent})
                    else
                        OptionButton:ChangeItemTheme({BackgroundColor3 = "Element", TextColor3 = "Text"})
                        OptionButton:Tween({BackgroundColor3 = Library.Theme["Element"]})
                    end
                end

                function OptionData:Set()
                    if Dropdown.Multi then
                        local Index = table.find(Dropdown.Value, OptionData.Name)
                        if Index then
                            table.remove(Dropdown.Value, Index)
                        else
                            table.insert(Dropdown.Value, OptionData.Name)
                        end
                        Dropdown:Set(Dropdown.Value)
                    else
                        Dropdown:Set(OptionData.Name)
                        Dropdown:SetOpen(false)
                    end
                end

                OptionButton:Connect("MouseButton1Down", function()
                    OptionData:Set()
                end)

                Dropdown.Options[Value] = OptionData
                return OptionData
            end

            function Dropdown:Remove(Value)
                if Dropdown.Options[Value] then
                    Dropdown.Options[Value].Button.Instance:Destroy()
                    Dropdown.Options[Value] = nil
                end
            end

            function Dropdown:Refresh(List)
                for _, Option in pairs(Dropdown.Options) do
                    Dropdown:Remove(Option.Name)
                end
                for _, Value in pairs(List) do
                    Dropdown:Add(Value)
                end
            end

            function Dropdown:SetText(Text)
                Items["Text"].Instance.Text = tostring(Text)
            end

            function Dropdown:SetVisibility(Bool)
                Items["Dropdown"].Instance.Visible = Bool
            end

            function Dropdown:SetOpen(Bool)
                if Dropdown.IsOpen == Bool then return end
                Dropdown.IsOpen = Bool
                
                if Bool then
                    local Scale = Library:GetScreenScale()
                    Items["OptionHolder"].Instance.Size = UDim2.new(0, Items["RealDropdown"].Instance.AbsoluteSize.X / Scale, 0, 0)
                    Items["OptionHolder"].Instance.Position = Library:PopupPosition(Items["RealDropdown"].Instance, Items["OptionHolder"].Instance, 0)
                    Items["OptionHolder"].Instance.Visible = true
                    Items["OptionHolder"]:Tween({Position = Library:PopupPosition(Items["RealDropdown"].Instance, Items["OptionHolder"].Instance, 5)})
                else
                    Items["OptionHolder"].Instance.Visible = false
                end
            end

            Library:Connect(UserInputService.InputBegan, function(Input)
                if Input.UserInputType == Enum.UserInputType.MouseButton1 and Dropdown.IsOpen then
                    if not Items["OptionHolder"]:IsMouseOverFrame() then
                        Dropdown:SetOpen(false)
                    end
                end
            end)

            Items["RealDropdown"]:Connect("MouseButton1Down", function()
                Dropdown:SetOpen(not Dropdown.IsOpen)
            end)

            for _, Value in pairs(Dropdown.OptionItems) do
                Dropdown:Add(Value)
            end

            Dropdown:Set(Dropdown.Default)

            Library.SetFlags[Dropdown.Flag] = function(Value)
                Dropdown:Set(Value)
            end

            return setmetatable(Dropdown, Library)
        end

        Library.Label = function(Self, Params)
            Params = Params or { }

            local Label = {
                Name = Params.Name or "Label",
                Section = Self,
                Items = { }
            }

            local Parent = Params.Parent or Label.Section.Items["Content"]

            local Items = { } do 
                Items["Label"] = Library:Create("Frame", {
                    Parent = Parent.Instance,
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 0, 14),
                    BorderSizePixel = 0
                })
                
                Items["Text"] = Library:Create("TextLabel", {
                    FontFace = Library.Font,
                    TextSize = Library.FontSize,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    Parent = Items["Label"].Instance,
                    TextColor3 = Library.Theme["Text"],
                    Text = Label.Name,
                    BackgroundTransparency = 1,
                    BorderSizePixel = 0,
                    AutomaticSize = Enum.AutomaticSize.XY
                }):AddToTheme({TextColor3 = 'Text'})
                
                Items["SubElements"] = Library:Create("Frame", {
                    Parent = Items["Label"].Instance,
                    AnchorPoint = Vector2.new(1, 0),
                    BackgroundTransparency = 1,
                    Position = UDim2.new(1, 0, 0, 0),
                    Size = UDim2.new(0, 0, 1, 0),
                    BorderSizePixel = 0,
                    AutomaticSize = Enum.AutomaticSize.X
                })
                
                Library:Create("UIListLayout", {
                    Parent = Items["SubElements"].Instance,
                    VerticalAlignment = Enum.VerticalAlignment.Center,
                    FillDirection = Enum.FillDirection.Horizontal,
                    Padding = UDim.new(0, 8)
                })

                Label.Items = Items
            end

            function Label:SetVisibility(Bool)
                Items["Label"].Instance.Visible = Bool
            end

            function Label:SetText(Text)
                Items["Text"].Instance.Text = tostring(Text)
            end

            function Label:Colorpicker(Data)
                Data = Data or { }
                Data.Parent = Items["SubElements"]
                Data.Section = Label.Section
                return Library:CreateColorpicker(Data)
            end

            function Label:Keybind(Data)
                Data = Data or { }
                Data.Parent = Items["SubElements"]
                Data.Section = Label.Section
                return Library:CreateKeybind(Data)
            end

            return setmetatable(Label, Library)
        end

        Library.Textbox = function(Self, Params)
            Params = Params or { }

            local Textbox = {
                Name = Params.Name or "Textbox",
                Flag = Params.Flag or Params.Name or "Textbox",
                Default = Params.Default or "",
                Callback = Params.Callback or function() end,
                Finished = Params.Finished or false,
                Placeholder = Params.Placeholder or "",
                Numeric = Params.Numeric or false,
                Section = Self,
                Value = "",
                Items = {}
            }

            local Parent = Params.Parent or Textbox.Section.Items["Content"]

            local Items = { } do 
                Items["Textbox"] = Library:Create("Frame", {
                    Parent = Parent.Instance,
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 0, 40),
                    BorderSizePixel = 0
                })
                
                Items["Text"] = Library:Create("TextLabel", {
                    FontFace = Library.Font,
                    TextSize = Library.FontSize,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    Parent = Items["Textbox"].Instance,
                    TextColor3 = Library.Theme["Text"],
                    Text = Textbox.Name,
                    BackgroundTransparency = 1,
                    BorderSizePixel = 0,
                    AutomaticSize = Enum.AutomaticSize.XY
                }):AddToTheme({TextColor3 = 'Text'})
                
                Items["Input"] = Library:Create("TextBox", {
                    FontFace = Library.Font,
                    TextSize = Library.FontSize,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    Parent = Items["Textbox"].Instance,
                    PlaceholderColor3 = Library.Theme["Inactive Text"],
                    PlaceholderText = Textbox.Placeholder,
                    Size = UDim2.new(1, 0, 0, 20),
                    TextColor3 = Library.Theme["Text"],
                    Text = "",
                    AnchorPoint = Vector2.new(0, 1),
                    Position = UDim2.new(0, 0, 1, 0),
                    BackgroundColor3 = Library.Theme["Element"],
                    BorderSizePixel = 0,
                    ClearTextOnFocus = false
                }):AddToTheme({BackgroundColor3 = 'Element', TextColor3 = 'Text', PlaceholderColor3 = 'Inactive Text'})

                Textbox.Items = Items
            end

            function Textbox:SetVisibility(Bool)
                Items["Textbox"].Instance.Visible = Bool
            end

            function Textbox:SetText(Text)
                Items["Text"].Instance.Text = tostring(Text)
            end

            function Textbox:Set(Value)
                if Textbox.Numeric and tostring(Value) ~= "" and not tonumber(Value) then
                    return
                end
                Textbox.Value = Value
                Items["Input"].Instance.Text = Value
                Library.Flags[Textbox.Flag] = Value
                Library:SafeCall(Textbox.Callback, Value)
            end

            if Textbox.Finished then
                Items["Input"]:Connect("FocusLost", function()
                    Textbox:Set(Items["Input"].Instance.Text)
                end)
            else
                Items["Input"]:Connect("Changed", function(Property)
                    if Property == "Text" then
                        Textbox:Set(Items["Input"].Instance.Text)
                    end
                end)
            end

            Textbox:Set(Textbox.Default)

            Library.SetFlags[Textbox.Flag] = function(Value)
                Textbox:Set(Value)
            end

            return setmetatable(Textbox, Library)
        end

        Library.Init = function(Self)
            local SettingsPage = Self:Page({Name = "Settings"})
            
            local ThemingSection = SettingsPage:Section({Name = "Theming", Side = 2})
            for Index, Value in pairs(Library.Theme) do
                local Colorpicker = ThemingSection:Label({Name = Index}):Colorpicker({
                    Name = Index,
                    Flag = Index .. "Theming",
                    Default = Value,
                    Callback = function(Color)
                        Library:ChangeTheme(Index, Color)
                    end
                })
            end

            local ThemeSelected = nil
            local ThemeName = ""
            local ThemesFolder = Library.Directory .. Library.Folders.Themes .. "/"

            local ThemesDropdown = ThemingSection:Dropdown({
                Name = "Load Theme",
                Flag = "LoadTheme",
                Items = {},
                Callback = function(Value)
                    ThemeSelected = Value
                end
            })

            ThemingSection:Textbox({
                Name = "Theme Name",
                Flag = "ThemeName",
                Placeholder = "Enter theme name",
                Callback = function(Value)
                    ThemeName = Value
                end
            })

            ThemingSection:Button({
                Name = "Save Theme",
                Callback = function()
                    if ThemeName and ThemeName ~= "" then
                        local ThemeData = {}
                        for Index, Value in pairs(Library.Theme) do
                            ThemeData[Index .. "Theming"] = {Color = "#" .. Value:ToHex(), Alpha = 0}
                        end
                        writefile(ThemesFolder .. ThemeName .. ".json", HttpService:JSONEncode(ThemeData))
                        Library:GetThemesList(ThemesDropdown)
                        Library:Notification("Saved theme: " .. ThemeName, 2)
                    end
                end
            })

            ThemingSection:Button({
                Name = "Load Theme",
                Callback = function()
                    if ThemeSelected and isfile(ThemesFolder .. ThemeSelected .. ".json") then
                        local ThemeData = HttpService:JSONDecode(readfile(ThemesFolder .. ThemeSelected .. ".json"))
                        for Index, Value in pairs(ThemeData) do
                            if Value.Color then
                                local ThemeIndex = Index:gsub("Theming", "")
                                if Library.Theme[ThemeIndex] then
                                    Library:ChangeTheme(ThemeIndex, Color3.fromHex(Value.Color))
                                end
                            end
                        end
                        Library:Notification("Loaded theme: " .. ThemeSelected, 2)
                    end
                end
            })

            ThemingSection:Button({
                Name = "Delete Theme",
                Callback = function()
                    if ThemeSelected and isfile(ThemesFolder .. ThemeSelected .. ".json") then
                        delfile(ThemesFolder .. ThemeSelected .. ".json")
                        Library:GetThemesList(ThemesDropdown)
                        Library:Notification("Deleted theme: " .. ThemeSelected, 2)
                    end
                end
            })

            Library:GetThemesList(ThemesDropdown)

            local ConfigSection = SettingsPage:Section({Name = "Configs", Side = 1})
            local ConfigSelected = nil
            local ConfigName = ""
            local ConfigsFolder = Library.Directory .. Library.Folders.Configs .. "/"

            local ConfigsList = ConfigSection:List({
                Name = "Configs",
                Flag = "ConfigsList",
                Items = {},
                Callback = function(Value)
                    ConfigSelected = Value
                end
            })

            ConfigSection:Textbox({
                Name = "Config Name",
                Flag = "ConfigNameText",
                Placeholder = "Enter config name",
                Callback = function(Value)
                    ConfigName = Value
                end
            })

            ConfigSection:Button({
                Name = "Save Config",
                Callback = function()
                    if ConfigName and ConfigName ~= "" then
                        writefile(ConfigsFolder .. ConfigName .. ".json", Library:GetConfig())
                        Library:GetConfigsList(ConfigsList)
                        Library:Notification("Saved config: " .. ConfigName, 2)
                    end
                end
            })

            ConfigSection:Button({
                Name = "Load Config",
                Callback = function()
                    if ConfigSelected and isfile(ConfigsFolder .. ConfigSelected .. ".json") then
                        Library:LoadConfig(readfile(ConfigsFolder .. ConfigSelected .. ".json"))
                        Library:Notification("Loaded config: " .. ConfigSelected, 2)
                    end
                end
            })

            ConfigSection:Button({
                Name = "Delete Config",
                Callback = function()
                    if ConfigSelected and isfile(ConfigsFolder .. ConfigSelected .. ".json") then
                        delfile(ConfigsFolder .. ConfigSelected .. ".json")
                        Library:GetConfigsList(ConfigsList)
                        Library:Notification("Deleted config: " .. ConfigSelected, 2)
                    end
                end
            })

            ConfigSection:Button({
                Name = "Set as Autoload",
                Callback = function()
                    if ConfigSelected and isfile(ConfigsFolder .. ConfigSelected .. ".json") then
                        writefile(Library.Directory .. "/autoload.json", readfile(ConfigsFolder .. ConfigSelected .. ".json"))
                        Library:Notification("Set " .. ConfigSelected .. " as autoload", 2)
                    end
                end
            })

            ConfigSection:Button({
                Name = "Clear Autoload",
                Callback = function()
                    writefile(Library.Directory .. "/autoload.json", "")
                    Library:Notification("Cleared autoload", 2)
                end
            })

            Library:GetConfigsList(ConfigsList)

            local MenuSection = SettingsPage:Section({Name = "Menu", Side = 1})
            
            MenuSection:Button({
                Name = "Exit",
                Callback = function()
                    Library:Exit()
                end
            })

            MenuSection:Label({Name = "Menu Keybind"}):Keybind({
                Name = "Menu Keybind",
                Flag = "MenuKeybind",
                Default = Enum.KeyCode.X,
                Mode = "Toggle",
                Callback = function()
                    Library.MenuKeybind = Library.Flags["MenuKeybind"] and Library.Flags["MenuKeybind"].Key or "X"
                end
            })

            if Self.Watermark then
                MenuSection:Toggle({
                    Name = "Show Watermark",
                    Flag = "ShowWatermark",
                    Default = true,
                    Callback = function(Value)
                        Self.Watermark:SetVisibility(Value)
                    end
                })
            end

            if Self.KeybindList then
                MenuSection:Toggle({
                    Name = "Show Keybinds",
                    Flag = "ShowKeybinds",
                    Default = true,
                    Callback = function(Value)
                        Self.KeybindList:SetVisibility(Value)
                    end
                })
            end

            local AutoloadContent = readfile(Library.Directory .. "/autoload.json")
            if AutoloadContent ~= "" then
                task.spawn(function()
                    Library:LoadConfig(AutoloadContent)
                end)
            end
        end
    end
end

getgenv().Library = Library
return Library
